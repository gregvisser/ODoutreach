// OpensDoors — cold outreach platform (multi-tenant)
// All tenant-owned data references Client (tenant) for strict isolation.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ——— Enums ———

enum StaffRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

/// Tracks Microsoft Graph B2B guest invitation lifecycle for staff provisioned from the app.
enum StaffGuestInvitationState {
  NONE
  PENDING
  ACCEPTED
}

enum ClientLifecycleStatus {
  ONBOARDING
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ClientMemberRole {
  LEAD
  CONTRIBUTOR
  VIEWER
}

enum ContactSource {
  CSV_IMPORT
  ROCKETREACH
  MANUAL
}

enum ImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RocketReachJobStatus {
  PENDING
  FETCHED
  FAILED
  STALE
}

enum SuppressionListKind {
  EMAIL
  DOMAIN
}

enum SuppressionSyncStatus {
  NOT_CONFIGURED
  IDLE
  SYNCING
  SUCCESS
  ERROR
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
}

/// Per-client email template category (PR D4a). Each template fills one
/// slot in the introduction → follow-up ladder. Sequences (PR D4b+) pick
/// one template per step.
enum ClientEmailTemplateCategory {
  INTRODUCTION
  FOLLOW_UP_1
  FOLLOW_UP_2
  FOLLOW_UP_3
  FOLLOW_UP_4
  FOLLOW_UP_5
}

/// Approval lifecycle for a client email template (PR D4a). Only
/// APPROVED templates are eligible for future sequence selection; DRAFT
/// and READY_FOR_REVIEW are editable; ARCHIVED is a soft-delete that
/// keeps history.
enum ClientEmailTemplateStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  ARCHIVED
}

/// Approval lifecycle for a client email sequence (PR D4b). Mirrors the
/// template lifecycle so the same mental model applies: DRAFT while the
/// operator composes it, READY_FOR_REVIEW once it is complete, APPROVED
/// once OpensDoors staff sign off, ARCHIVED as a soft-delete. APPROVED
/// is a record-only marker in D4b — no send/schedule logic is wired to
/// it yet.
enum ClientEmailSequenceStatus {
  DRAFT
  READY_FOR_REVIEW
  APPROVED
  ARCHIVED
}

/// PR D4c — per-contact enrollment lifecycle. Records-only in this
/// PR: there is no scheduler or step-send worker attached. PAUSED is
/// intended as an operator-initiated hold. EXCLUDED is reserved for
/// a future "preserve excluded row for visibility" path — today the
/// enrollment writer skips ineligible contacts with counts rather
/// than persisting EXCLUDED rows.
enum ClientEmailSequenceEnrollmentStatus {
  PENDING
  PAUSED
  COMPLETED
  EXCLUDED
}

enum OutboundEmailStatus {
  /// Legacy — prefer REQUESTED for new rows
  PREPARING
  /// Validated send request; not yet in worker pool
  REQUESTED
  /// Eligible for outbound worker (provider send not yet completed)
  QUEUED
  /// Worker claimed — provider API call in flight
  PROCESSING
  /// Suppression check failed — never sent
  BLOCKED_SUPPRESSION
  /// Provider accepted the message (API success)
  SENT
  /// Terminal provider/transport failure (may be retried → back to QUEUED)
  FAILED
  /// Bounce reported by provider webhook
  BOUNCED
  DELIVERED
  /// Inbound reply linked to this send (operational milestone)
  REPLIED
}

enum InboundMatchMethod {
  UNLINKED
  BY_OUTBOUND_PROVIDER_ID
  BY_THREAD_REF
  BY_CONTACT_EMAIL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  SYNC
  IMPORT
}

/// Workspace sender readiness (not full DNS UI — operational gating)
enum SenderIdentityStatus {
  NOT_SET
  CONFIGURED_UNVERIFIED
  VERIFIED_READY
}

/// Outreach mailbox provider (Microsoft 365 vs Google Workspace)
enum MailboxProvider {
  MICROSOFT
  GOOGLE
}

/// OAuth / connection lifecycle for a client mailbox identity (records-only in early slices)
enum MailboxConnectionStatus {
  DRAFT
  PENDING_CONNECTION
  CONNECTED
  CONNECTION_ERROR
  DISCONNECTED
}

/// Per-mailbox send reservation / cap ledger (UTC day window) — for duplicate-safe bookings before worker send.
enum MailboxSendReservationStatus {
  RESERVED
  CONSUMED
  RELEASED
}

// ——— Staff (Microsoft Entra object id — oid claim) ———

model StaffUser {
  id                       String                    @id @default(cuid())
  entraObjectId            String                    @unique
  /// Normalized (lowercase/trim) — unique so first-login can match by email then attach entraObjectId
  email                    String                    @unique
  displayName              String?
  role                     StaffRole                 @default(OPERATOR)
  isActive                 Boolean                   @default(true)
  guestInvitationState     StaffGuestInvitationState @default(NONE)
  invitedAt                DateTime?
  invitationLastSentAt     DateTime?
  invitedById              String?
  invitedBy                StaffUser?                @relation("StaffInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedStaff             StaffUser[]               @relation("StaffInvitedBy")
  /// Microsoft Graph invitation resource id (from POST /invitations)
  graphInvitationId        String?                   @unique
  /// Object id of the invited guest user in the tenant (from invitation response)
  graphInvitedUserObjectId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships              ClientMembership[]
  auditLogs                AuditLog[]
  outboundSends            OutboundEmail[]         @relation("OutboundInitiator")
  mailboxIdentitiesCreated ClientMailboxIdentity[] @relation("MailboxIdentityCreatedBy")
  contactListsCreated      ContactList[]           @relation("ContactListCreatedBy")
  contactListMembersAdded  ContactListMember[]     @relation("ContactListMemberAddedBy")
  emailTemplatesCreated    ClientEmailTemplate[]   @relation("ClientEmailTemplateCreatedBy")
  emailTemplatesApproved   ClientEmailTemplate[]   @relation("ClientEmailTemplateApprovedBy")
  emailSequencesCreated    ClientEmailSequence[]   @relation("ClientEmailSequenceCreatedBy")
  emailSequencesApproved   ClientEmailSequence[]   @relation("ClientEmailSequenceApprovedBy")
  sequenceEnrollmentsCreated ClientEmailSequenceEnrollment[] @relation("ClientEmailSequenceEnrollmentCreatedBy")

  @@index([invitedById])
}

// ——— Tenant / workspace ———

model Client {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  status               ClientLifecycleStatus @default(ONBOARDING)
  industry             String?
  website              String?
  notes                String?
  /// Opaque token for inbound webhook URL — maps to this tenant only
  inboundIngestToken   String                @unique @default(cuid())
  /// Default From: for outbound (operational placeholder until per-mailbox config)
  defaultSenderEmail   String?
  /// Provider/domain verification is tracked outside this app until integrated — gates real sends when enforced
  senderIdentityStatus SenderIdentityStatus  @default(NOT_SET)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  memberships             ClientMembership[]
  onboarding              ClientOnboarding?
  contacts                Contact[]
  contactLists            ContactList[]
  contactListMembers      ContactListMember[]
  importBatches           ContactImportBatch[]
  rocketReachJobs         RocketReachEnrichment[]
  suppressionSources      SuppressionSource[]
  suppressedEmails        SuppressedEmail[]
  suppressedDomains       SuppressedDomain[]
  campaigns               Campaign[]
  outboundEmails          OutboundEmail[]
  inboundReplies          InboundReply[]
  reportingSnapshots      ReportingDailySnapshot[]
  auditLogs               AuditLog[]
  outboundProviderEvents  OutboundProviderEvent[]
  mailboxIdentities       ClientMailboxIdentity[]
  /// Microsoft Graph–ingested inbox rows (idempotent by mailbox + Graph message id)
  inboundMailboxMessages  InboundMailboxMessage[]
  mailboxSendReservations MailboxSendReservation[]
  emailTemplates          ClientEmailTemplate[]
  emailSequences          ClientEmailSequence[]
  sequenceEnrollments     ClientEmailSequenceEnrollment[]

  @@index([status])
}

/// Connected outreach sending/receiving identity for a client workspace (max 5 active per client).
model ClientMailboxIdentity {
  id                   String                  @id @default(cuid())
  clientId             String
  provider             MailboxProvider
  /// Normalized lowercase email — single source of truth for display and uniqueness
  email                String
  emailNormalized      String
  displayName          String?
  connectionStatus     MailboxConnectionStatus @default(DRAFT)
  isActive             Boolean                 @default(true)
  isPrimary            Boolean                 @default(false)
  /// Provider capability — future send/reply integration
  canSend              Boolean                 @default(true)
  canReceive           Boolean                 @default(true)
  /// OpensDoors hard rule: default 30 sends per mailbox per rolling/window day (enforced in later slices)
  dailySendCap         Int                     @default(30)
  /// Operator toggle to pause sending without deleting the row
  isSendingEnabled     Boolean                 @default(true)
  /// Counters reset when `now` passes `dailyWindowResetAt` (worker/sync responsibility in later slices)
  emailsSentToday      Int                     @default(0)
  dailyWindowResetAt   DateTime?
  lastSyncAt           DateTime?
  lastError            String?                 @db.Text
  /// Opaque CSRF value for in-flight OAuth (Microsoft / Google mailbox connection)
  oauthState           String?                 @unique
  oauthStateExpiresAt  DateTime?
  /// Provider account id after connect (e.g. Google `sub`, Microsoft Graph `id`) — not a secret
  providerLinkedUserId String?
  connectedAt          DateTime?
  createdByStaffUserId String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  client                Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy             StaffUser?               @relation("MailboxIdentityCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  secret                MailboxIdentitySecret?
  graphIngestedMessages InboundMailboxMessage[]
  sendReservations      MailboxSendReservation[]
  outboundSends         OutboundEmail[]

  @@unique([clientId, emailNormalized])
  @@index([clientId, isActive])
  @@index([createdByStaffUserId])
}

/// Server-side OAuth token material for a mailbox identity (never exposed to the client UI).
model MailboxIdentitySecret {
  id                  String          @id @default(cuid())
  mailboxIdentityId   String          @unique
  provider            MailboxProvider
  /// AES-GCM payload (base64) — JSON with refresh_token, access_token, expires_at, scope, etc.
  encryptedCredential String          @db.Text
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  mailbox ClientMailboxIdentity @relation(fields: [mailboxIdentityId], references: [id], onDelete: Cascade)
}

/// Inbox rows ingested from Microsoft Graph (delegated Mail.Read) — not ESP webhooks.
model InboundMailboxMessage {
  id                String   @id @default(cuid())
  clientId          String
  mailboxIdentityId String
  /// Microsoft Graph message id (id property)
  providerMessageId String
  fromEmail         String
  toEmail           String?
  subject           String?  @db.Text
  /// Short preview; avoid storing full body in this slice
  snippet           String?  @db.Text
  bodyPreview       String?  @db.Text
  receivedAt        DateTime
  /// Graph conversationId (threading)
  conversationId    String?
  /// e.g. MICROSOFT_GRAPH — extensible
  ingestionSource   String   @default("MICROSOFT_GRAPH")
  /// Opaque: internetMessageId, odata, etc. (no raw MIME)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client  Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mailbox ClientMailboxIdentity @relation(fields: [mailboxIdentityId], references: [id], onDelete: Cascade)

  @@unique([mailboxIdentityId, providerMessageId])
  @@index([clientId, receivedAt])
  @@index([mailboxIdentityId, receivedAt])
}

model ClientMembership {
  id          String           @id @default(cuid())
  staffUserId String
  clientId    String
  role        ClientMemberRole @default(CONTRIBUTOR)
  createdAt   DateTime         @default(now())
  staffUser   StaffUser        @relation(fields: [staffUserId], references: [id], onDelete: Cascade)
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([staffUserId, clientId])
  @@index([clientId])
}

model ClientOnboarding {
  id             String    @id @default(cuid())
  clientId       String    @unique
  currentStep    Int       @default(1)
  completedSteps Json      @default("[]")
  /// JSON blob: basics, suppression sheet refs, outreach prefs — flexible for the wizard
  formData       Json      @default("{}")
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ——— Contacts & imports ———

model ContactImportBatch {
  id           String            @id @default(cuid())
  clientId     String
  fileName     String?
  rowCount     Int               @default(0)
  status       ImportBatchStatus @default(PENDING)
  errorMessage String?
  /// Import outcome: created, skipped, duplicates, sample errors — JSON
  summary      Json?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contacts     Contact[]

  @@index([clientId, createdAt])
}

model Contact {
  id                     String        @id @default(cuid())
  clientId               String
  email                  String
  /// Optional full name from CSV / enrichment
  fullName               String?
  /// Normalized domain part of email (lowercase), for display and guards
  emailDomain            String?
  firstName              String?
  lastName               String?
  company                String?
  title                  String?
  /// First-class outreach identifiers from the CSV/RocketReach import contract
  /// (docs/ops/CLIENT_WORKSPACE_MODULE_AUDIT.md §0.1). A contact is valid when
  /// it is not suppressed AND has at least one of email / linkedIn /
  /// mobilePhone / officePhone. Email remains required today; email-optional
  /// persistence is a deferred follow-up.
  linkedIn               String?
  mobilePhone            String?
  officePhone            String?
  location               String?
  city                   String?
  country                String?
  source                 ContactSource @default(MANUAL)
  importBatchId          String?
  /// Cached flag after suppression check (refresh on sync)
  isSuppressed           Boolean       @default(false)
  lastSuppressionCheckAt DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  client          Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importBatch     ContactImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  rocketReach     RocketReachEnrichment?
  outboundEmails  OutboundEmail[]
  inboundReplies  InboundReply[]
  listMemberships ContactListMember[]
  sequenceEnrollments ClientEmailSequenceEnrollment[]

  @@unique([clientId, email])
  @@index([clientId])
  @@index([importBatchId])
}

/// Named reusable list of contacts (universal-contact bridge, PR D1).
/// Per docs/ops/UNIVERSAL_CONTACTS_AND_LISTS_PLAN.md §0.1 (Option A):
/// a list is either global (`clientId = null`) or belongs to exactly one
/// client. Many-to-many list↔client is deferred until a later PR.
/// Dedupe is by `Contact.email` today; LinkedIn/phone dedupe is deferred
/// per §0.5. Nothing in this PR (D1) reads or writes these rows yet —
/// the UI and import paths start using them in PR D2.
model ContactList {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  clientId             String?
  createdByStaffUserId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  client    Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy StaffUser?            @relation("ContactListCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  members   ContactListMember[]
  sequences ClientEmailSequence[]
  sequenceEnrollments ClientEmailSequenceEnrollment[]

  @@index([clientId])
  @@index([name])
  @@index([createdByStaffUserId])
}

/// Join table for ContactList ↔ Contact (PR D1). Idempotent per pair via
/// `@@unique([contactListId, contactId])`. Contact ownership still lives
/// on `Contact.clientId` until PR D5 backfill.
///
/// Tenant-isolation (critical): `clientId` is denormalized from the row's
/// `Contact.clientId` and enforced by a DB trigger
/// (`ContactListMember_client_scope_guard`) so that:
///   * `clientId` must equal `Contact.clientId` for `contactId`.
///   * If the target `ContactList.clientId` is non-null, it must match
///     `clientId` — a client-scoped list can only contain same-client
///     contacts.
///   * A global list (`ContactList.clientId IS NULL`) can hold contacts
///     from any client, but each row still pins the contact's client
///     scope via `clientId`.
/// See migration 20260420200000_contact_lists_additive for the trigger.
model ContactListMember {
  id                 String   @id @default(cuid())
  contactListId      String
  contactId          String
  clientId           String
  addedByStaffUserId String?
  addedAt            DateTime @default(now())

  contactList ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  addedBy     StaffUser?  @relation("ContactListMemberAddedBy", fields: [addedByStaffUserId], references: [id], onDelete: SetNull)

  @@unique([contactListId, contactId])
  @@index([contactId])
  @@index([clientId])
  @@index([addedByStaffUserId])
}

model RocketReachEnrichment {
  id         String               @id @default(cuid())
  clientId   String
  contactId  String?              @unique
  externalId String?
  status     RocketReachJobStatus @default(PENDING)
  rawPayload Json?
  lastError  String?
  fetchedAt  DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([externalId])
}

// ——— Suppression (Google Sheets source of truth per tenant) ———

model SuppressionSource {
  id                  String                @id @default(cuid())
  clientId            String
  kind                SuppressionListKind
  /// Google Spreadsheet ID
  spreadsheetId       String?
  /// Sheet name or gid reference
  sheetRange          String?
  label               String?
  syncStatus          SuppressionSyncStatus @default(NOT_CONFIGURED)
  lastSyncedAt        DateTime?
  lastError           String?
  /// Opaque ref to stored OAuth / service account (never raw tokens in DB)
  googleConnectionRef String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  suppressedEmails  SuppressedEmail[]
  suppressedDomains SuppressedDomain[]

  @@index([clientId, kind])
}

model SuppressedEmail {
  id       String             @id @default(cuid())
  clientId String
  email    String
  sourceId String?
  syncedAt DateTime           @default(now())
  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source   SuppressionSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([clientId, email])
  @@index([clientId])
}

model SuppressedDomain {
  id       String             @id @default(cuid())
  clientId String
  domain   String
  sourceId String?
  syncedAt DateTime           @default(now())
  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source   SuppressionSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@unique([clientId, domain])
  @@index([clientId])
}

// ——— Outreach (not CRM) ———

model Campaign {
  id          String         @id @default(cuid())
  clientId    String
  name        String
  status      CampaignStatus @default(DRAFT)
  description String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  outboundEmails OutboundEmail[]

  @@index([clientId, status])
}

/// Per-client email template library (PR D4a — foundation only).
///
/// OpensDoors staff author messages per client, mark them ready for
/// review, then approve them. Only APPROVED templates will be eligible
/// for future sequences (PR D4b+). Sending is NOT implemented here:
/// this model has no send-time fields and is not referenced by any
/// outbound worker.
///
/// Placeholders are validated in application code
/// (`src/lib/email-templates/placeholders.ts`); unknown placeholders
/// block approval but are allowed in DRAFT / READY_FOR_REVIEW so
/// operators can iterate.
model ClientEmailTemplate {
  id                    String                      @id @default(cuid())
  clientId              String
  name                  String
  category              ClientEmailTemplateCategory
  subject               String                      @db.Text
  content               String                      @db.Text
  status                ClientEmailTemplateStatus   @default(DRAFT)
  createdByStaffUserId  String?
  approvedByStaffUserId String?
  approvedAt            DateTime?
  archivedAt            DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy    StaffUser? @relation("ClientEmailTemplateCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  approvedBy   StaffUser? @relation("ClientEmailTemplateApprovedBy", fields: [approvedByStaffUserId], references: [id], onDelete: SetNull)
  sequenceSteps ClientEmailSequenceStep[]

  @@index([clientId])
  @@index([clientId, status])
  @@index([clientId, category])
  @@index([createdByStaffUserId])
  @@index([approvedByStaffUserId])
}

/// Per-client email sequence (PR D4b — records-only foundation).
///
/// A sequence pairs one client-scoped `ContactList` with an ordered set
/// of steps (`ClientEmailSequenceStep`), each referencing one APPROVED
/// `ClientEmailTemplate`. Approval is OpensDoors-gated and does NOT
/// schedule or send email — sending / scheduling is intentionally
/// deferred to a later PR. The D4b UI + server helpers enforce
/// cross-table invariants (sequence↔list client match, step↔template
/// client match, step category === template category, only APPROVED
/// templates in APPROVED sequences) in the application layer.
model ClientEmailSequence {
  id                    String                    @id @default(cuid())
  clientId              String
  contactListId         String
  name                  String
  description           String?
  status                ClientEmailSequenceStatus @default(DRAFT)
  createdByStaffUserId  String?
  approvedByStaffUserId String?
  approvedAt            DateTime?
  archivedAt            DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  client       Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contactList  ContactList               @relation(fields: [contactListId], references: [id], onDelete: Restrict)
  createdBy    StaffUser?                @relation("ClientEmailSequenceCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)
  approvedBy   StaffUser?                @relation("ClientEmailSequenceApprovedBy", fields: [approvedByStaffUserId], references: [id], onDelete: SetNull)
  steps        ClientEmailSequenceStep[]
  enrollments  ClientEmailSequenceEnrollment[]

  @@index([clientId])
  @@index([clientId, status])
  @@index([contactListId])
  @@index([createdByStaffUserId])
  @@index([approvedByStaffUserId])
}

/// Ordered step inside a `ClientEmailSequence` (PR D4b). Each row pins
/// a single template at a single category slot — unique per
/// `(sequenceId, position)` and per `(sequenceId, category)` so a
/// sequence can hold at most one INTRODUCTION, one FOLLOW_UP_1, etc.
/// `delayDays` is records-only metadata for a future scheduler.
model ClientEmailSequenceStep {
  id         String                      @id @default(cuid())
  sequenceId String
  templateId String
  category   ClientEmailTemplateCategory
  position   Int
  delayDays  Int                         @default(0)
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  sequence ClientEmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  template ClientEmailTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@unique([sequenceId, position])
  @@unique([sequenceId, category])
  @@index([templateId])
}

/// Per-contact enrollment in a `ClientEmailSequence` (PR D4c — records only).
///
/// An enrollment is the operator-visible record that a specific
/// contact from the sequence's target `ContactList` will walk the
/// sequence. This PR introduces records only — there is no scheduler,
/// no send worker, and no step-send trigger attached to this model.
/// Per-step sends land in PR D4e.
///
/// Invariants (enforced in application layer —
/// `src/server/email-sequences/enrollments.ts`):
///   * `enrollment.clientId === sequence.clientId` (tenant isolation)
///   * `enrollment.contactListId === sequence.contactListId`
///   * `enrollment.contactId` is a member of the sequence's list
///   * contact must be email-sendable at enrollment time unless the
///     row is explicitly marked `EXCLUDED` (not written today — the
///     enrollment writer skips ineligible contacts with counts)
///   * `(sequenceId, contactId)` is unique so re-running enrollment
///     is idempotent and cannot duplicate a recipient
model ClientEmailSequenceEnrollment {
  id                   String                                @id @default(cuid())
  clientId             String
  sequenceId           String
  contactId            String
  contactListId        String
  status               ClientEmailSequenceEnrollmentStatus  @default(PENDING)
  /// Free-form operator note when status === EXCLUDED (e.g. "suppressed at enroll time").
  exclusionReason      String?
  /// 0 means not started; step-send wiring in PR D4e advances this.
  currentStepPosition  Int                                   @default(0)
  enrolledAt           DateTime                              @default(now())
  pausedAt             DateTime?
  completedAt          DateTime?
  createdByStaffUserId String?
  createdAt            DateTime                              @default(now())
  updatedAt            DateTime                              @updatedAt

  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sequence    ClientEmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  contact     Contact             @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactList ContactList         @relation(fields: [contactListId], references: [id], onDelete: Restrict)
  createdBy   StaffUser?          @relation("ClientEmailSequenceEnrollmentCreatedBy", fields: [createdByStaffUserId], references: [id], onDelete: SetNull)

  @@unique([sequenceId, contactId])
  @@index([clientId])
  @@index([sequenceId, status])
  @@index([contactId])
  @@index([contactListId])
  @@index([createdByStaffUserId])
}

model OutboundEmail {
  id                     String              @id @default(cuid())
  /// Stable id for provider/webhook correlation (duplicate of id purpose; explicit for APIs)
  correlationId          String              @unique @default(cuid())
  clientId               String
  campaignId             String?
  contactId              String?
  staffUserId            String?
  /// ESP message id (SendGrid/Postmark/etc.)
  providerMessageId      String?
  /// e.g. mock, resend, postmark
  providerName           String?
  fromAddress            String?
  toEmail                String
  /// Normalized recipient domain for indexing
  toDomain               String?
  subject                String?
  /// Rendered/plain snapshot for ops (not for CRM)
  bodySnapshot           String?             @db.Text
  status                 OutboundEmailStatus @default(QUEUED)
  failureReason          String?
  lastErrorCode          String?
  lastErrorMessage       String?             @db.Text
  /// Last normalized provider lifecycle label (delivered, bounced, etc.)
  lastProviderEventType  String?
  /// Raw provider-reported status string when available
  providerStatus         String?
  bounceCategory         String?
  retryCount             Int                 @default(0)
  lastAttemptAt          DateTime?
  nextRetryAt            DateTime?
  /// Optional: sending mailbox identity (cap enforcement) — set when a governed mailbox is chosen for the send
  mailboxIdentityId      String?
  /// Worker claim — stale claims can be stolen after claimExpiresAt
  claimedAt              DateTime?
  claimExpiresAt         DateTime?
  /// Increments each time a worker claims this row from QUEUED → PROCESSING (idempotency scope)
  sendAttempt            Int                 @default(0)
  /// Deterministic per claim — passed to ESP Idempotency-Key when supported
  providerIdempotencyKey String?             @unique
  /// Last provider webhook / lifecycle event time applied (ordering guard)
  lastProviderEventAt    DateTime?
  /// When blocked by suppression — audit trail
  suppressionSnapshot    Json?
  queuedAt               DateTime?
  attemptedAt            DateTime?
  sentAt                 DateTime?
  deliveredAt            DateTime?
  bouncedAt              DateTime?
  openedAt               DateTime?
  metadata               Json?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign        Campaign?               @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  contact         Contact?                @relation(fields: [contactId], references: [id], onDelete: SetNull)
  staffUser       StaffUser?              @relation("OutboundInitiator", fields: [staffUserId], references: [id], onDelete: SetNull)
  mailbox         ClientMailboxIdentity?  @relation(fields: [mailboxIdentityId], references: [id], onDelete: SetNull)
  sendReservation MailboxSendReservation?
  inboundReplies  InboundReply[]          @relation("ReplyToOutbound")
  providerEvents  OutboundProviderEvent[]

  @@index([clientId, createdAt])
  @@index([clientId, sentAt])
  @@index([clientId, status])
  @@index([contactId])
  @@index([providerMessageId])
  @@index([correlationId])
  @@index([status, nextRetryAt, queuedAt])
  @@index([mailboxIdentityId, sentAt])
}

model MailboxSendReservation {
  id                String                       @id @default(cuid())
  clientId          String
  mailboxIdentityId String
  /// Deduplication scope for a booking attempt (per mailbox + UTC day in windowKey)
  idempotencyKey    String
  /// UTC date key YYYY-MM-DD (same for all users — cap resets at 00:00 UTC)
  windowKey         String
  status            MailboxSendReservationStatus @default(RESERVED)
  /// Populated when an OutboundEmail row is created for this slot
  outboundEmailId   String?                      @unique
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt

  client   Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mailbox  ClientMailboxIdentity @relation(fields: [mailboxIdentityId], references: [id], onDelete: Cascade)
  outbound OutboundEmail?        @relation(fields: [outboundEmailId], references: [id], onDelete: SetNull)

  @@unique([mailboxIdentityId, windowKey, idempotencyKey])
  @@index([mailboxIdentityId, windowKey, status])
  @@index([clientId, createdAt])
}

/// Append-only provider webhook / event audit (delivery, bounce, etc.)
model OutboundProviderEvent {
  id                String   @id @default(cuid())
  clientId          String?
  outboundEmailId   String?
  providerName      String
  eventType         String
  providerMessageId String?
  /// Svix / provider message id — same replay shares id
  webhookMessageId  String?
  /// sha256 fingerprint for idempotent insert (replay detection)
  dedupeHash        String   @unique
  payload           Json?
  createdAt         DateTime @default(now())
  receivedAt        DateTime @default(now())
  /// Whether outbound row state was mutated (vs metadata-only / skipped)
  stateMutated      Boolean  @default(false)
  replayDuplicate   Boolean  @default(false)
  processingNote    String?

  client   Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  outbound OutboundEmail? @relation(fields: [outboundEmailId], references: [id], onDelete: SetNull)

  @@index([providerMessageId])
  @@index([webhookMessageId])
  @@index([outboundEmailId])
  @@index([clientId, receivedAt])
}

model InboundReply {
  id                    String             @id @default(cuid())
  clientId              String
  contactId             String?
  /// Linked outbound when match is confident and same-tenant
  linkedOutboundEmailId String?
  threadId              String?
  /// Provider's message id for this inbound message
  providerMessageId     String?
  /// In-Reply-To / References provider id we stored on outbound
  inReplyToProviderId   String?
  fromEmail             String
  toEmail               String?
  subject               String?
  snippet               String?
  bodyPreview           String?
  receivedAt            DateTime
  /// webhook | dev_simulate | polling_stub
  ingestionSource       String             @default("webhook")
  matchMethod           InboundMatchMethod @default(UNLINKED)
  metadata              Json?
  createdAt             DateTime           @default(now())

  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  linkedOutbound OutboundEmail? @relation("ReplyToOutbound", fields: [linkedOutboundEmailId], references: [id], onDelete: SetNull)

  @@index([clientId, receivedAt])
  @@index([providerMessageId])
  @@index([linkedOutboundEmailId])
}

// ——— Reporting aggregates (placeholder / nightly rollups) ———

model ReportingDailySnapshot {
  id              String   @id @default(cuid())
  clientId        String
  date            DateTime @db.Date
  emailsSent      Int      @default(0)
  repliesReceived Int      @default(0)
  uniqueContacts  Int      @default(0)
  campaignsActive Int      @default(0)
  replyRate       Float?
  createdAt       DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, date])
  @@index([clientId, date])
}

// ——— Audit ———

model AuditLog {
  id          String      @id @default(cuid())
  staffUserId String?
  clientId    String?
  action      AuditAction
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  staffUser StaffUser? @relation(fields: [staffUserId], references: [id], onDelete: SetNull)
  client    Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([staffUserId, createdAt])
}
