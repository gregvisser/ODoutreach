# =============================================================================
# Copy to .env locally. NEVER commit .env — only this file is tracked.
#
# Where to set values:
#   Local:        .env (gitignored)
#   Azure App Service: Configuration → Application settings (use Key Vault for production if desired)
#   GitHub CI:    Repository → Settings → Secrets and variables → Actions (see docs/GITHUB_SETUP.md)
# =============================================================================

# --- Core (required everywhere the app runs) ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/opensdoors_outreach?schema=public"
# Azure PostgreSQL: use SSL, e.g. ...?sslmode=require
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"

# --- First Azure staging deploy (typical minimum beyond core) ---
# Long random string — protects POST /api/internal/outbound/process-queue and GET queue-status
PROCESS_QUEUE_SECRET=""
# Local dev: http://localhost:3000 | Azure staging: https://your-app.azurewebsites.net
INTERNAL_APP_URL="http://localhost:3000"
# Local dev: true (in-process drain). Staging/Azure: false — use worker/cron; production Node also ignores in-process autoprocess.
AUTOPROCESS_OUTBOUND_QUEUE="true"
# Restrict staff sign-in to these email domains (comma-separated); empty = policy disabled in code paths that check it
STAFF_EMAIL_DOMAINS=""

# --- Real email on staging (optional until you prove Resend) ---
EMAIL_PROVIDER="mock"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# --- Optional product integrations ---
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""
ROCKETREACH_API_KEY=""
SEED_CLERK_USER_ID=""

# --- Outbound / inbound tuning ---
DEFAULT_OUTBOUND_FROM=""
ALLOWED_SENDER_EMAIL_DOMAINS=""
INBOUND_WEBHOOK_SECRET=""
OUTBOUND_QUEUE_BATCH_SIZE="8"
MAX_OUTBOUND_SEND_RETRIES="5"

# --- Production-sensitive: rotate per environment; never log or commit ---
# (No extra keys here — treat all secrets above as sensitive in production.)

# --- Local-only / dev routes (omit on Azure staging unless you explicitly need them) ---
OUTBOUND_DEV_QUEUE_SECRET=""
ALLOW_DEV_OUTBOUND_QUEUE=""
OUTBOUND_DEV_PROVIDER_EVENT_SECRET=""
ALLOW_DEV_PROVIDER_SIMULATE=""
OUTBOUND_DEV_WEBHOOK_REPLAY_SECRET=""
ALLOW_DEV_WEBHOOK_REPLAY=""
INBOUND_DEV_SIMULATE_SECRET=""
ALLOW_DEV_INBOUND_SIMULATE=""
