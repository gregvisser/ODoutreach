# =============================================================================
# Copy to .env locally. NEVER commit .env — only this file is tracked.
#
# Microsoft Entra (Azure AD) — app registration + client secret; set redirect URI:
#   https://<your-host>/api/auth/callback/microsoft-entra-id
#
# Where to set values:
#   Local: .env (gitignored)
#   Azure App Service: Configuration → Application settings
#   GitHub CI: workflow env (placeholders) — see .github/workflows/ci.yml
# =============================================================================

# --- Core ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/opensdoors_outreach?schema=public"

# --- Auth.js / NextAuth (Microsoft Entra ID) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Base URL of this app (Auth.js uses this for OAuth redirects). Local: http://localhost:3000
AUTH_URL="http://localhost:3000"
# Paste from Entra app registration → Overview: Application (client) ID
AUTH_MICROSOFT_ENTRA_ID_ID=""
# Paste client secret value (Certificates & secrets — not the secret ID)
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# Single-tenant:
#   https://login.microsoftonline.com/<TENANT_ID>/v2.0/
# Multi-tenant (workforce sign-in from more than one Entra directory):
#   https://login.microsoftonline.com/common/v2.0
#   (or /organizations/v2.0) — then you MUST set ALLOWED_ENTRA_TENANT_IDS.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# When using /common/ or /organizations/ as the issuer, list every
# directory (tenant) UUID allowed to sign in (e.g. Bidlow + OpensDoors).
# Comma-separated, lowercase or mixed. Empty with a multi-tenant issuer
# means no-one can sign in.
ALLOWED_ENTRA_TENANT_IDS=""

# --- In-app staff invitations (Microsoft Graph, client credentials) ---
# Uses the same Entra app as Auth.js. In Entra: API permissions → Microsoft Graph → Application:
#   User.Invite.All, User.Read.All — then Grant admin consent.
# Token uses AUTH_MICROSOFT_ENTRA_ID_ID + AUTH_MICROSOFT_ENTRA_ID_SECRET and tenant from issuer.
# Optional explicit tenant GUID if issuer parsing is insufficient:
# AUTH_TENANT_ID=""
# Optional override for guest redemption landing (default: AUTH_URL + /sign-in):
# STAFF_INVITE_REDIRECT_URL="https://opensdoors.bidlow.co.uk/sign-in"

# --- First Azure staging deploy (typical minimum beyond core + auth) ---
PROCESS_QUEUE_SECRET=""
INTERNAL_APP_URL="http://localhost:3000"
AUTOPROCESS_OUTBOUND_QUEUE="true"
# Comma-separated; only staff whose email ends with these domains may use the UI when set.
# For real Entra verification use your org domains, e.g. bidlow.co.uk,opensdoors.co.uk
# Leave empty only for quick local UI work without domain gating.
STAFF_EMAIL_DOMAINS=""

# --- Email (optional until real ESP) ---
EMAIL_PROVIDER="mock"
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""

# --- Mailbox OAuth (Microsoft 365 / Google Workspace) — separate from staff Entra SSO ---
# Encrypts stored refresh tokens; use a long random value (e.g. openssl rand -base64 32).
# Falls back to AUTH_SECRET if unset (not recommended for production).
MAILBOX_OAUTH_SECRET=""
# Azure AD app registration for delegated mailbox access (not the same redirect URIs as Auth.js staff login).
# Register redirect: {AUTH_URL}/api/mailbox-oauth/microsoft/callback
MAILBOX_MICROSOFT_OAUTH_CLIENT_ID=""
MAILBOX_MICROSOFT_OAUTH_CLIENT_SECRET=""
# Tenant segment for authorize/token URLs: common | organizations | your tenant GUID
MAILBOX_MICROSOFT_OAUTH_TENANT="common"
# Google Cloud OAuth client (Desktop or Web). Register redirect: {AUTH_URL}/api/mailbox-oauth/google/callback
MAILBOX_GOOGLE_OAUTH_CLIENT_ID=""
MAILBOX_GOOGLE_OAUTH_CLIENT_SECRET=""

# --- Azure Maps (server-side) — UK Brief business address search ---
# Get a subscription key (Azure portal → your Maps account → Authentication).
# Set on App Service as an Application setting. Never expose this key in the client bundle.
AZURE_MAPS_SUBSCRIPTION_KEY=""

# --- Optional product integrations ---
GOOGLE_SERVICE_ACCOUNT_JSON=""
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""
ROCKETREACH_API_KEY=""
# Seed: Entra object id (oid claim) for the demo StaffUser row — optional if you set seed email to your work address (first login links oid by email).
SEED_ENTRA_OBJECT_ID=""

# --- Outbound / inbound tuning ---
DEFAULT_OUTBOUND_FROM=""
ALLOWED_SENDER_EMAIL_DOMAINS=""
INBOUND_WEBHOOK_SECRET=""
OUTBOUND_QUEUE_BATCH_SIZE="8"
MAX_OUTBOUND_SEND_RETRIES="5"

# --- Dev-only routes (omit on Azure staging unless needed) ---
OUTBOUND_DEV_QUEUE_SECRET=""
ALLOW_DEV_OUTBOUND_QUEUE=""
OUTBOUND_DEV_PROVIDER_EVENT_SECRET=""
ALLOW_DEV_PROVIDER_SIMULATE=""
OUTBOUND_DEV_WEBHOOK_REPLAY_SECRET=""
ALLOW_DEV_WEBHOOK_REPLAY=""
INBOUND_DEV_SIMULATE_SECRET=""
ALLOW_DEV_INBOUND_SIMULATE=""
